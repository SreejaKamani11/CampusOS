# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/campusos

# CORS — frontend origin (Vite default)
CORS_ORIGIN=http://localhost:5173

# JWT (reserved for authentication module — not used yet)
JWT_SECRET=change-me-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# File uploads (reserved for printout module)
UPLOAD_DIR=uploads/printouts
